# ============================================================
# OYA MICRO-CREDIT KENYA — Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ─── Node Environment ──────────────────────────────────────
NODE_ENV=development

# ─── Supabase / PostgreSQL ─────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/oya_microcredit?schema=public
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=ypur_service_role_key
SUPABASE_STORAGE_BUCKET=oya-documents

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_256_BIT_RANDOM_HEX_IN_PRODUCTION
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── Services Internal Ports ───────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
LOAN_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
AUDIT_SERVICE_PORT=3005

# ─── Safaricom Daraja (M-Pesa) ─────────────────────────────
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_BUSINESS_SHORT_CODE=174379
DARAJA_PASSKEY=your_passkey
DARAJA_CALLBACK_URL=https://api.oyamicrocredit.co.ke/payments/callback
DARAJA_ACCOUNT_REFERENCE=OYAMicroCredit
DARAJA_TRANSACTION_DESC=Loan Repayment

# ─── Africa's Talking (SMS) ────────────────────────────────
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=OYA

# ─── Firebase (FCM Push Notifications) ────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ─── Email (Resend or SMTP) ────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@oyamicrocredit.co.ke

# ─── Sentry ────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://admin.oyamicrocredit.co.ke

# ─── Admin Dashboard ───────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Cloudflare ────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_zone_id

# ─── Monitoring ────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3030
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ─── Backblaze B2 (Backup Storage) ────────────────────────
B2_APPLICATION_KEY_ID=your_b2_key_id
B2_APPLICATION_KEY=your_b2_app_key
B2_BUCKET_NAME=oya-backups

# ─── Encryption (for backup archives) ──────────────────────
BACKUP_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ─── App Version Control ───────────────────────────────────
APP_MIN_VERSION_ANDROID=1.0.0
APP_LATEST_VERSION_ANDROID=1.0.0
APP_MIN_VERSION_IOS=1.0.0
APP_LATEST_VERSION_IOS=1.0.0
